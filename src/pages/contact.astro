---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Contact - KSP2 Redux</title>
	<meta name="description" content="Get in touch with the KSP2 Redux team and community.">
	<link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="bg-space-black text-white min-h-screen">
	<Header />

	<!-- Page Header -->
	<section class="pt-24 pb-12 bg-gradient-to-b from-ksp-blue to-space-black">
		<div class="section-container text-center">
			<h1 class="text-5xl md:text-6xl font-heading font-extrabold mb-4 text-glow">
				Get In <span class="text-ksp-red">Touch</span>
			</h1>
			<p class="text-xl text-gray-300 max-w-2xl mx-auto">
				Join our thriving community, report issues, or contribute to the project.
			</p>
		</div>
	</section>

	<!-- Contact Options -->
	<section class="section-container py-16">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
			<!-- Discord -->
			<a 
				href="https://discord.gg/ksp2redux" 
				target="_blank"
				class="card-glass text-center hover:scale-105 transition-all duration-300 hover:border-ksp-red border-2 border-transparent"
			>
				<div class="text-6xl mb-4">
					<svg class="w-16 h-16 mx-auto text-ksp-red" fill="currentColor" viewBox="0 0 24 24">
						<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
					</svg>
				</div>
				<h3 class="text-2xl font-heading font-bold mb-3">Discord</h3>
				<p class="text-gray-400 mb-4">
					Join 5,000+ community members for real-time support, discussions, and community events.
				</p>
				<span class="text-ksp-red font-semibold">
					Join Server →
				</span>
			</a>

			<!-- GitHub -->
			<a 
				href="https://github.com/KSP2Redux/Redux" 
				target="_blank"
				class="card-glass text-center hover:scale-105 transition-all duration-300 hover:border-ksp-red border-2 border-transparent"
			>
				<div class="text-6xl mb-4">
					<svg class="w-16 h-16 mx-auto text-ksp-red" fill="currentColor" viewBox="0 0 24 24">
						<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
					</svg>
				</div>
				<h3 class="text-2xl font-heading font-bold mb-3">GitHub</h3>
				<p class="text-gray-400 mb-4">
					Report bugs, contribute code, or track development progress.
				</p>
				<span class="text-ksp-red font-semibold">
					View Repository →
				</span>
			</a>

			<!-- Reddit -->
			<a 
				href="https://reddit.com/r/KSP2Redux" 
				target="_blank"
				class="card-glass text-center hover:scale-105 transition-all duration-300 hover:border-ksp-red border-2 border-transparent"
			>
				<div class="text-6xl mb-4">
					<svg class="w-16 h-16 mx-auto text-ksp-red" fill="currentColor" viewBox="0 0 24 24">
						<path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701z"/>
					</svg>
				</div>
				<h3 class="text-2xl font-heading font-bold mb-3">Reddit</h3>
				<p class="text-gray-400 mb-4">
					Share your builds, ask questions, and engage with the community.
				</p>
				<span class="text-ksp-red font-semibold">
					Visit Subreddit →
				</span>
			</a>
		</div>

		<!-- Quick Links -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Documentation -->
			<div class="card-glass">
				<h3 class="text-2xl font-heading font-bold mb-4 flex items-center">
					<svg class="w-6 h-6 mr-3 text-ksp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
					</svg>
					Need Help?
				</h3>
				<p class="text-gray-400 mb-4">
					Check out our comprehensive documentation for installation guides, 
					troubleshooting tips, and FAQs.
				</p>
				<a href="/guides" class="btn-primary inline-block">
					Browse Documentation
				</a>
			</div>

			<!-- Report Issues -->
			<div class="card-glass">
				<h3 class="text-2xl font-heading font-bold mb-4 flex items-center">
					<svg class="w-6 h-6 mr-3 text-ksp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
					</svg>
					Found a Bug?
				</h3>
				<p class="text-gray-400 mb-4">
					Report bugs and issues on our GitHub repository. Include system specs 
					and reproduction steps.
				</p>
				<a href="https://github.com/KSP2Redux/Redux/issues" target="_blank" class="btn-primary inline-block">
					Report Issue
				</a>
			</div>
		</div>
	</section>

	<!-- FAQ Link Section -->
	<section class="bg-gradient-to-b from-space-black to-ksp-blue py-20">
		<div class="section-container text-center">
			<h2 class="text-4xl font-heading font-bold mb-6">
				Browse Our <span class="text-ksp-red">FAQ</span>
			</h2>
			<p class="text-gray-400 mb-8 max-w-2xl mx-auto text-lg">
				Check out our comprehensive FAQ for answers to common questions about installation, 
				compatibility, safety, and more.
			</p>
			<a href="/faq" class="btn-primary text-lg">
				<svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
				View FAQ
			</a>
		</div>
	</section>

	<!-- Project Leads Section -->
	<section class="section-container py-20">
		<h2 class="text-4xl font-heading font-bold mb-12 text-center">
			Project <span class="text-ksp-red">Leads</span>
		</h2>
		<p class="text-center text-gray-300 mb-12 max-w-2xl mx-auto">
			Project Leads are responsible for specific branches of development. Have a question about an area of development? Feel free to reach out to the corresponding Lead!
		</p>
		
		<div class="overflow-x-auto">
			<table class="w-full border-collapse">
				<thead>
					<tr class="border-b-2 border-ksp-red">
						<th class="text-left py-4 px-6 font-heading font-bold text-ksp-red">Lead</th>
						<th class="text-left py-4 px-6 font-heading font-bold text-ksp-red">Responsibilities</th>
					</tr>
				</thead>
				<tbody>
					<tr class="border-b border-gray-700 hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">Foonix</td>
						<td class="py-4 px-6 text-gray-300">Performance &amp; Improvements, Bug Fixing</td>
					</tr>
					<tr class="border-b border-gray-700 hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">Munix</td>
						<td class="py-4 px-6 text-gray-300">Gameplay, Public Relations, Modding Support</td>
					</tr>
					<tr class="border-b border-gray-700 hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">ShadowDev</td>
						<td class="py-4 px-6 text-gray-300">Features</td>
					</tr>
					<tr class="border-b border-gray-700 hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">Lexi</td>
						<td class="py-4 px-6 text-gray-300">Modding Support</td>
					</tr>
					<tr class="border-b border-gray-700 hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">The Space Peacock</td>
						<td class="py-4 px-6 text-gray-300">Gameplay, Bug Hunting, Text and Localization</td>
					</tr>
					<tr class="hover:bg-gray-900/30 transition-colors">
						<td class="py-4 px-6 font-semibold text-white">Safarte</td>
						<td class="py-4 px-6 text-gray-300">Art, Gameplay</td>
					</tr>
				</tbody>
			</table>
		</div>
		
		<p class="text-center text-gray-400 mt-8 text-sm">
			You can reach out to any lead through our Discord server for questions or collaboration opportunities.
		</p>
	</section>

	<!-- Final CTA -->
	<section class="section-container py-20">
		<div class="card-glass text-center py-12">
			<h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">
				Still Have Questions?
			</h2>
			<p class="text-gray-400 mb-6 max-w-xl mx-auto">
				Our community is here to help! Join Discord for instant support.
			</p>
			<a href="https://discord.gg/ksp2redux" target="_blank" class="btn-primary text-lg">
				<svg class="w-5 h-5 inline-block mr-2" fill="currentColor" viewBox="0 0 24 24">
					<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
				</svg>
				Join Our Discord
			</a>
		</div>
	</section>

	<Footer />
</body>
</html>
