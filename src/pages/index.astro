---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { latestVersion } from '../data/data';

---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>KSP2 Redux</title>
	<meta name="description" content="KSP2 Redux is a community-made continuation patch for Kerbal Space Program 2, focused on bug fixes, performance work, and finishing the game.">
	<link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="bg-space-black text-white">
	<Header />

	<section class="page-hero page-hero--simple pt-24 pb-10">
		<div class="absolute inset-0 z-0" style="background-image: url('/background.png'); background-size: cover; background-position: center;"></div>
		<div class="absolute inset-0 z-0 bg-gradient-to-r from-space-black via-space-black/80 to-space-black/30"></div>
		<div class="absolute inset-0 z-0 bg-gradient-to-b from-transparent via-transparent to-space-black"></div>

		<div class="section-container relative z-10">
			<div class="home-hero-copy">
				<h1 class="page-title">
					KSP2
					<span>Redux</span>
				</h1>

				<p class="home-version">{latestVersion}</p>

				<p class="page-intro">
					KSP2 Redux is a community project focused on fixing Kerbal Space Program 2, improving performance,
					and finishing systems that were left incomplete.
				</p>

				<p class="home-context">
					This site is for downloads, installation docs, release notes, roadmap progress, and contributor-facing
					documentation.
				</p>

				<div class="home-action-row">
					<a href="https://github.com/KSP2Redux/Updater/releases/latest" target="_blank" rel="noopener noreferrer" class="btn-primary">
						Download latest build
					</a>
					<a href="/guides/installation" class="btn-secondary">
						Installation guide
					</a>
					<a href="/blog" class="btn-secondary">
						Release notes and blog
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section-container py-12">
		<div class="page-section-heading">
			<h2>Start here</h2>
			<p>
				If you are new to Redux, these are the pages that matter first.
			</p>
		</div>

		<div class="home-entry-grid">
			<a href="/guides/installation" class="card-glass home-entry-card">
				<h3>Installation guide</h3>
				<p>How to install Redux, which builds are supported, and where to start troubleshooting.</p>
			</a>
			<a href="/roadmap" class="card-glass home-entry-card">
				<h3>Roadmap</h3>
				<p>Current priorities, already added content, and larger systems still planned for later.</p>
			</a>
			<a href="/blog" class="card-glass home-entry-card">
				<h3>Development blog</h3>
				<p>Release posts, technical writeups, previews, and progress notes from ongoing work.</p>
			</a>
		</div>
	</section>

	<section class="section-container py-12">
		<div class="home-summary">
			<div class="page-section-heading">
				<h2>What Redux is for</h2>
			</div>
			<div class="home-summary__body">
				<p>
					In the Foundation stage, Redux is mainly about practical repair work: performance, bug fixing, UI cleanup, and getting
					core game systems into a state that people can actually play and build on.
				</p>
				<p>
					It is also used to improve the game as a modding base, with better tooling, better debugging,
					and more predictable workflows for Redux mods.
				</p>
			</div>
		</div>
	</section>

	<section class="section-container py-12">
		<div class="page-section-heading">
			<h2>Links</h2>
			<p>
				Discord is where most support and testing discussion happens. GitHub is for releases, source, and issue tracking. Reddit and the forum are useful for broader public discussion.
			</p>
		</div>

		<div class="home-community-grid">
			<a href="https://discord.gg/8yq8d5VGQR" target="_blank" rel="noopener noreferrer" class="card-glass home-community-card">
				<h3>Discord</h3>
				<p>Testing coordination, support questions, and most day-to-day discussion.</p>
				<span class="home-community-card__textlink">Join Discord</span>
			</a>
			<a href="https://github.com/KSP2Redux/Redux" target="_blank" rel="noopener noreferrer" class="card-glass home-community-card">
				<h3>GitHub</h3>
				<p>Release builds, changelogs, and the public issue tracker.</p>
				<span class="home-community-card__textlink">Open GitHub</span>
			</a>
			<a href="https://forum.kerbalspaceprogram.com/topic/226985-ksp2-redux" target="_blank" rel="noopener noreferrer" class="card-glass home-community-card">
				<h3>KSP Forums</h3>
				<p>The KSP forums thread for announcements and discussion.</p>
				<span class="home-community-card__textlink">Open forum thread</span>
			</a>
			<a href="https://reddit.com/r/KSP2Redux" target="_blank" rel="noopener noreferrer" class="card-glass home-community-card">
				<h3>Reddit</h3>
				<p>Community posts, screenshots, and general discussion outside of Discord.</p>
				<span class="home-community-card__textlink">Open subreddit</span>
			</a>
		</div>
	</section>

	<Footer />
</body>
</html>

<style>
	.home-action-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 1.75rem;
	}

	.home-hero-copy {
		max-width: 46rem;
	}

	.home-version {
		margin: 0.85rem 0 0;
		color: #9ca3af;
		font-family: var(--font-family-heading);
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.home-context {
		max-width: 40rem;
		margin: 1.2rem 0 0;
		color: #9ca3af;
		line-height: 1.75;
	}

	.home-entry-grid,
	.home-community-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.home-entry-card,
	.home-community-card {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.home-entry-card h3,
	.home-community-card h3 {
		margin: 0;
		font-family: var(--font-family-heading);
		font-size: 1.5rem;
		line-height: 1.15;
	}

	.home-entry-card p:last-child,
	.home-community-card p {
		margin: 0.85rem 0 0;
		color: #d1d5db;
		line-height: 1.75;
	}

	.home-summary {
		display: grid;
		gap: 1rem;
	}

	.home-summary__body {
		max-width: 48rem;
		color: #d1d5db;
		line-height: 1.75;
	}

	.home-summary__body p {
		margin: 0;
	}

	.home-summary__body p + p {
		margin-top: 1rem;
	}

	.home-community-card__textlink {
		display: inline-block;
		margin-top: 1rem;
		color: #ff7f6b;
		font-weight: 700;
	}

	@media (min-width: 900px) {
		.home-entry-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.home-community-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	@media (max-width: 639px) {
		.home-action-row {
			flex-direction: column;
		}

		.home-action-row a {
			width: 100%;
		}
	}
</style>
