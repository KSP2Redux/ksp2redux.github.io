---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

import { latestVersion, releaseDate } from '../assets/version.json';

// Format the release date
const formattedDate = new Date(releaseDate).toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric'
});
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>KSP2 Redux</title>
	<meta name="description" content="KSP2 Redux is a free, community-made mod for the game Kerbal Space Program 2, aiming to implement most of the features promised by the original developers.">
	<link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body class="bg-space-black text-white">
	<Header />

	<!-- Masthead -->
	<section class="relative pt-32 pb-16 overflow-hidden">
		<div class="absolute inset-0 z-0 opacity-15" style="background-image: url('/background.png'); background-size: cover; background-position: center;"></div>
		<div class="absolute inset-0 z-0 bg-gradient-to-b from-ksp-blue/50 via-space-black/80 to-space-black"></div>

		<div class="section-container relative z-10">
			<div class="max-w-3xl">
				<h1 class="text-5xl md:text-7xl font-heading font-extrabold mb-6 text-glow">
					<span class="text-ksp-red font-logo">KSP2 Redux</span>
				</h1>

				<p class="text-lg md:text-xl text-gray-300 mb-6 leading-relaxed">
					KSP2 Redux is a free, community-made mod for the game <strong class="text-white">Kerbal Space Program 2</strong>,
					aiming to implement most of the features promised by the original developers.
				</p>

				<p class="text-sm text-gray-500 mb-8">
					Current Version <span class="text-gray-300 font-semibold">{latestVersion}</span>
					<span class="text-gray-600 mx-2">·</span>
					<span>{formattedDate}</span>
				</p>

				<div class="flex flex-wrap gap-3">
					<a href="https://github.com/KSP2Redux/Updater/releases/latest" target="_blank" rel="noopener noreferrer" class="btn-primary">
						<svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
						</svg>
						Download
					</a>
					<a href="/guides" class="btn-secondary">
						<svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
						</svg>
						Read the Docs
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Features Section -->
	<section class="section-container py-16">
		<div class="max-w-5xl">
			<h2 class="text-sm font-heading font-semibold uppercase tracking-[0.2em] text-gray-400 mb-3">Redux Features</h2>
			<div class="h-px bg-gradient-to-r from-ksp-red via-ksp-red/30 to-transparent mb-12"></div>

			<dl class="grid grid-cols-1 md:grid-cols-[14rem_1fr] gap-x-10 gap-y-10">
				<dt class="text-xl font-heading font-semibold text-white md:text-right">Performance Improvements</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					Reworked rendering, ECS/Burst, and memory handling push frame rates 30-56% above stock.
				</dd>

				<dt class="text-xl font-heading font-semibold text-white md:text-right">Bug Fixes</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					Hundreds of stock bugs patched, covering physics glitches, UI errors, and the game-breakers.
				</dd>

				<dt class="text-xl font-heading font-semibold text-white md:text-right">Planned Features</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					Colonies, resource management, interstellar travel, and multiplayer are all planned. These are the features KSP2 was originally meant to ship with.
				</dd>

				<dt class="text-xl font-heading font-semibold text-white md:text-right">Modding Support</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					A Unity Editor-based SDK, so mods can be built and iterated inside the engine instead of reloading the game.
				</dd>

				<dt class="text-xl font-heading font-semibold text-white md:text-right">The Team</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					Built by volunteer KSP2 modders on their own time, shaped by what the community actually asks for.
				</dd>

				<dt class="text-xl font-heading font-semibold text-white md:text-right">Debug Tools</dt>
				<dd class="text-gray-400 md:border-l md:border-white/10 md:pl-10">
					In-game debug windows for vessel info, science, teleportation, and Kerbal management.
				</dd>
			</dl>
		</div>
	</section>

	<!-- Showcase Section -->
