---
// Unified header component for all pages (custom + Starlight docs)
const { pathname } = Astro.url;

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/guides', label: 'Documentation' },
	{ href: '/blog', label: 'Blog' },
	// { href: '/gallery', label: 'Gallery' },
	{ href: '/faq', label: 'FAQ' },
	{ href: '/contact', label: 'Contact' },
];

// Detect if we're on a Starlight page
const isStarlight = pathname.startsWith('/guides') || pathname.startsWith('/blog');

// Desktop nav path checking
const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
};
---

<header class:list={["fixed top-0 left-0 right-0 z-50 bg-ksp-dark/95 backdrop-blur-md border-b border-white/10", isStarlight && "starlight-header"]}>
	<nav class="section-container">
		<div class="flex items-center justify-between h-16">
			<!-- Logo -->
			<a href="/" class="flex items-center space-x-3 group">
				<img 
					src="/src/assets/logo.png" 
					alt="KSP2 Redux Logo" 
					class="h-10 w-10 transition-transform duration-300 group-hover:scale-110"
				/>
				<span class="text-xl font-logo font-bold text-white">
					KSP2 Redux
				</span>
			</a>

			<!-- Desktop Navigation -->
			<div class="hidden md:flex items-center space-x-8">
				{navItems.map(item => (
					<a 
						href={item.href}
						class:list={[
							"text-sm font-medium transition-colors duration-200",
							isActive(item.href) ? "text-ksp-red" : "text-gray-300 hover:text-white"
						]}
					>
						{item.label}
					</a>
				))}
				
				<!-- GitHub Link -->
				<a 
					href="https://github.com/KSP2Redux/Redux" 
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-300 hover:text-white transition-colors duration-200"
					aria-label="GitHub"
				>
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
					</svg>
				</a>

				<!-- Download CTA -->
				<a 
					href="/#download" 
					class="btn-primary text-sm"
				>
					Download
				</a>
			</div>

			<!-- Mobile Menu Button -->
			<button 
				id="mobile-menu-button"
				class="md:hidden text-gray-300 hover:text-white focus:outline-none"
				aria-label="Toggle menu"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile Navigation -->
	<div id="mobile-menu" class="hidden md:hidden pb-4 px-4 border-t border-white/10">
		<div class="flex flex-col space-y-3 pt-4">
			{navItems.map(item => (
				<a href={item.href} class="text-gray-300 hover:text-white transition-colors py-2">
					{item.label}
				</a>
			))}
			<a href="/#download" class="btn-primary text-sm text-center">Download</a>
		</div>
	</div>
</header>

<script>
	// Mobile menu toggle
	const button = document.getElementById('mobile-menu-button');
	const menu = document.getElementById('mobile-menu');
	
	button?.addEventListener('click', () => {
		menu?.classList.toggle('hidden');
	});
</script>
