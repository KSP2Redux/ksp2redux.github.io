---

<footer class="site-footer bg-space-black border-t border-white/10 mt-16 w-full">
	<div class="section-container py-12">
		<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
			<!-- Brand Column -->
			<div class="col-span-1 md:col-span-2">
				<div class="flex items-center space-x-3 mb-4">
					<img 
						src="/logo.png" 
						alt="KSP2 Redux Logo" 
						class="h-10 w-10"
					/>
					<span class="text-xl font-logo font-bold text-white">
						KSP2 Redux
					</span>
				</div>
				<p class="text-gray-400 text-sm max-w-md mb-4">
					A comprehensive community overhaul for Kerbal Space Program 2, bringing enhanced performance, 
					bug fixes, and quality of life improvements to your space exploration experience.
				</p>
				<div class="flex space-x-4">
					{socialLinks.map(link => (
						<a 
							href={link.url}
							target="_blank"
							rel="noopener noreferrer"
							class="text-gray-400 hover:text-ksp-red transition-colors duration-200"
							aria-label={link.name}
						>
							<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[link.icon]} />
						</a>
					))}
				</div>
			</div>

			<!-- Quick Links -->
			<div>
				<h3 class="text-white font-heading font-semibold mb-4">Quick Links</h3>
				<ul class="space-y-2">
					{quickLinks.map(link => (
						<li><a href={link.href} class="text-gray-400 hover:text-ksp-red transition-colors text-sm">{link.label}</a></li>
					))}
				</ul>
			</div>

			<!-- Resources -->
			<div>
				<h3 class="text-white font-heading font-semibold mb-4">Resources</h3>
				<ul class="space-y-2">
					{resourceLinks.map(link => (
						<li>
							<a 
								href={link.href}
								{...link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
								class="text-gray-400 hover:text-ksp-red transition-colors text-sm"
							>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>
		</div>

		<!-- Footer Bottom -->
		<div class="border-t border-white/10 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
			<p class="text-gray-500 text-sm">
				© {currentYear} KSP2 Redux. A community project by passionate Kerbonauts.
			</p>
			<p class="text-gray-500 text-sm mt-4 md:mt-0">
				Kerbal Space Program is a trademark of Private Division, LLC.
			</p>
		</div>
	</div>
</footer>
