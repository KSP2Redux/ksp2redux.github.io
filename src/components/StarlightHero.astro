---
import { Image } from 'astro:assets';

const PAGE_TITLE_ID = '_top';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

const imageAttrs = {
	loading: 'eager' as const,
	decoding: 'async' as const,
	width: 400,
	height: 400,
	alt: image?.alt || '',
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;
if (image) {
	if ('file' in image) {
		darkImage = image.file;
	} else if ('dark' in image) {
		darkImage = image.dark;
		lightImage = image.light;
	} else {
		rawHtml = image.html;
	}
}

const hasMedia = Boolean(darkImage || lightImage || rawHtml);
---

<div class:list={['redux-hero', hasMedia && 'redux-hero--with-media']}>
	{
		darkImage && (
			<Image
				src={darkImage}
				{...imageAttrs}
				class:list={['redux-hero__media', { 'light:sl-hidden': Boolean(lightImage) }]}
			/>
		)
	}
	{lightImage && <Image src={lightImage} {...imageAttrs} class="redux-hero__media dark:sl-hidden" />}
	{rawHtml && <div class="redux-hero__media redux-hero__media-html sl-flex" set:html={rawHtml} />}

	<div class="redux-hero__copy sl-flex">
		<h1 id={PAGE_TITLE_ID} class="redux-hero__title" data-page-title set:html={title} />
		{tagline && <div class="redux-hero__tagline" set:html={tagline} />}
		{
			actions.length > 0 && (
				<div class="redux-hero__actions sl-flex">
					{actions.map(({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant = 'primary' }) => (
						<a
							href={href}
							class:list={[
								'redux-hero__button',
								`redux-hero__button--${variant}`,
								className,
							]}
							{...attrs}
						>
							{text}
							{icon?.html && <Fragment set:html={icon.html} />}
						</a>
					))}
				</div>
			)
		}
	</div>
</div>

<style>
	@layer starlight.components {
		.redux-hero {
			position: relative;
			display: grid;
			gap: 1.5rem;
			margin-bottom: 2rem;
			padding: 2rem;
			border: 1px solid rgba(255, 255, 255, 0.08);
			border-radius: 1.5rem;
			overflow: hidden;
			background:
				linear-gradient(90deg, rgba(10, 10, 10, 0.92) 0%, rgba(10, 10, 10, 0.82) 58%, rgba(10, 10, 10, 0.68) 100%),
				linear-gradient(180deg, rgba(223, 22, 1, 0.08) 0%, rgba(10, 10, 10, 0) 55%);
			box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
			isolation: isolate;
		}

		.redux-hero::before {
			content: '';
			position: absolute;
			inset: 0;
			z-index: -1;
			background:
				radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.12) 0 1px, transparent 1px) 0 0 / 170px 170px,
				radial-gradient(circle at 75% 45%, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px) 0 0 / 220px 220px;
			opacity: 0.65;
			pointer-events: none;
		}

		.redux-hero__copy {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
			max-width: 48rem;
		}

		.redux-hero__title {
			margin: 0;
			font-family: var(--font-family-logo);
			font-size: clamp(3rem, 8vw, 5.2rem);
			font-weight: 800;
			line-height: 0.98;
			letter-spacing: 0.04em;
			text-transform: uppercase;
			color: #ffffff;
		}

		.redux-hero__title :global(span) {
			display: block;
			color: #df1601;
		}

		.redux-hero__tagline {
			max-width: 42rem;
			color: #d1d5db;
			font-size: 1.05rem;
			line-height: 1.8;
		}

		.redux-hero__actions {
			flex-wrap: wrap;
			gap: 0.9rem;
			margin-top: 0.4rem;
		}

		.redux-hero__button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.7rem;
			min-height: 3.35rem;
			padding: 0.9rem 1.45rem;
			border: 1px solid transparent;
			border-radius: 999px;
			font-size: 0.98rem;
			font-weight: 700;
			line-height: 1.2;
			letter-spacing: 0.01em;
			text-decoration: none;
			transition:
				transform 0.2s ease,
				border-color 0.2s ease,
				background-color 0.2s ease,
				box-shadow 0.2s ease,
				color 0.2s ease;
		}

		.redux-hero__button--primary {
			background: linear-gradient(180deg, #f02c16 0%, #df1601 100%);
			box-shadow:
				0 16px 32px rgba(223, 22, 1, 0.24),
				inset 0 1px 0 rgba(255, 255, 255, 0.18);
			color: #ffffff;
		}

		.redux-hero__button--primary:hover {
			transform: translateY(-2px);
			background: linear-gradient(180deg, #ff4029 0%, #e41901 100%);
			box-shadow:
				0 22px 38px rgba(223, 22, 1, 0.3),
				inset 0 1px 0 rgba(255, 255, 255, 0.22);
			color: #ffffff;
		}

		.redux-hero__button--secondary {
			border-color: rgba(255, 255, 255, 0.14);
			background: rgba(255, 255, 255, 0.05);
			box-shadow:
				inset 0 1px 0 rgba(255, 255, 255, 0.08),
				0 10px 24px rgba(0, 0, 0, 0.18);
			color: #ffffff;
		}

		.redux-hero__button--secondary:hover {
			transform: translateY(-2px);
			border-color: rgba(223, 22, 1, 0.4);
			background: rgba(255, 255, 255, 0.1);
		}

		.redux-hero__button--minimal {
			padding-inline: 0;
			border-color: transparent;
			background: transparent;
			color: #ffffff;
		}

		.redux-hero__button--minimal:hover {
			color: #ff7f6b;
		}

		.redux-hero__button:focus-visible {
			outline: 2px solid rgba(255, 255, 255, 0.9);
			outline-offset: 3px;
		}

		.redux-hero__media {
			width: min(100%, 22rem);
			height: auto;
			object-fit: contain;
			margin-inline: auto;
		}

		.redux-hero__media-html {
			align-items: center;
			justify-content: center;
		}

		@media (min-width: 50rem) {
			.redux-hero--with-media {
				grid-template-columns: minmax(0, 1.35fr) minmax(16rem, 0.75fr);
				align-items: center;
				gap: 2rem;
				padding: 2.5rem;
			}

			.redux-hero--with-media .redux-hero__media,
			.redux-hero--with-media .redux-hero__media-html {
				order: 2;
				justify-self: end;
			}
		}
	}
</style>
